.root
  position: relative
  margin-bottom: 16px
  display: flex
  width: 100%
  height: 110px
  flex-shrink: 0
  background-color: inherit

.preview
  flex-shrink: 0
  position: relative
  width: 110px
  height: 100%
  border-radius: 8px
  overflow: hidden
  user-select: none

  > canvas
  > img
  > div
    position: absolute
    top: 0
    right: 0
    bottom: 0
    left: 0
    width: 110px
    height: 110px
    border-radius: 8px

  > img
    display: block
    object-fit: cover

.description
  display: flex
  flex-direction: column
  justify-content: space-around
  width: calc(100% - 110px)
  padding-left: 16px
  font-weight: var(--font-weight-content)
  user-select: none

.title
  width: calc(100% - 32px)
  user-select: none

.footer
  display: flex
  width: calc(100% - 4px)
  user-select: none

  > span
    font-size: 12px

    &:last-child:not(:first-child)
      margin-left: auto
      color: var(--default-font-color)

.loader
  position: absolute
  top: 8px
  right: 0
  width: 16px
  height: 16px

.menu
  top: 0
  right: -8px
  width: 32px
  height: 32px
  border-radius: 0 8px 0 0

.cancelButton
  position: absolute
  top: 0
  right: -8px
  width: 32px
  height: 32px
  border-radius: 0 8px 0 0

._image
._video
._audio
  .preview
    cursor: pointer

/* Single-message card (grid): header + square preview + footer */
._single
  flex-direction: column
  height: auto
  margin-bottom: 0
  width: 100%
  background-color: transparent

.cardHeader
  display: flex
  flex-direction: row
  align-items: center
  flex-shrink: 0
  gap: 10px
  min-height: 44px
  padding: 10px 0px 8px 12px
  box-sizing: border-box

.cardHeaderIcon
  flex-shrink: 0
  width: 32px
  height: 32px
  border-radius: 8px
  overflow: hidden

  > div
    width: 100%
    height: 100%
    font-size: 10px

.cardTitle
  flex: 1
  min-width: 0
  font-size: 14px
  line-height: 18px
  color: var(--default-font-color)
  font-weight: var(--font-weight-content)

.cardHeaderLoader
  flex-shrink: 0
  width: 16px
  height: 16px

.cardMenu
  position: relative !important
  top: auto !important
  right: auto !important
  left: auto !important
  flex-shrink: 0
  width: 36px
  height: 36px
  border-radius: 8px

.cardCancelButton
  position: relative
  top: auto
  right: auto
  flex-shrink: 0
  width: 32px
  height: 32px
  border-radius: 8px

.cardPreview
  position: relative
  width: 100%
  aspect-ratio: 1
  overflow: hidden
  background-color: var(--color-black-01)
  user-select: none
  cursor: default

.cardPreviewInner
  position: absolute
  top: 0
  right: 0
  bottom: 0
  left: 0
  display: flex
  align-items: center
  justify-content: center

  > canvas
  > img
    position: absolute
    top: 0
    right: 0
    bottom: 0
    left: 0
    width: 100%
    height: 100%
    object-fit: cover
    border-radius: 0 0 10px 10px

  > div
    position: absolute
    top: 0
    right: 0
    bottom: 0
    left: 0
    display: flex
    align-items: center
    justify-content: center
    width: 100% !important
    height: 100% !important
    max-width: none
    border-radius: 0 0 10px 10px

    > svg
      width: 40px
      height: 40px

._image._single,
._video._single,
._audio._single
  .cardPreview
    cursor: pointer

.cardFooter
  display: flex
  flex-direction: row
  align-items: center
  justify-content: space-between
  gap: 8px
  padding: 8px 12px 12px
  box-sizing: border-box

.cardFooterText
  font-size: 12px
  min-width: 0

  &:last-child:not(:first-child)
    margin-left: auto
    color: var(--default-font-color)
