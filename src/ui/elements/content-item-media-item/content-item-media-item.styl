.root
  position: relative
  margin-bottom: 0
  display: flex
  flex-direction: column
  width: 100%
  box-sizing: border-box
  padding: 8px
  flex-shrink: 0
  border-radius: 8px
  background-color: inherit

.preview
  flex-shrink: 0
  position: relative
  width: 100%
  height: auto
  aspect-ratio: 1 / 1
  border-radius: 4px
  overflow: hidden
  user-select: none

  > canvas
  > img
  > div
    position: absolute
    top: 0
    right: 0
    bottom: 0
    left: 0
    width: 100%
    height: 100%
    border-radius: 4px

  > img
    display: block
    object-fit: cover

.description
  display: flex
  align-items: center
  width: 100%
  min-height: 32px
  padding: 0 36px 8px 0
  font-weight: var(--font-weight-content)
  user-select: none

.title
  width: 100%
  user-select: none

.loader
  position: absolute
  top: 8px
  right: 8px
  width: 16px
  height: 16px

.menu
  top: 0
  right: 0
  width: 32px
  height: 32px
  border-radius: 0 8px 0 0

.cancelButton
  position: absolute
  top: 0
  right: 0
  width: 32px
  height: 32px
  border-radius: 0 8px 0 0

._image
._video
._audio
  .preview
    cursor: pointer

._single
  margin-bottom: 0
