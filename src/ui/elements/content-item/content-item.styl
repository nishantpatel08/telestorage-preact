.root
  position: relative
  flex-shrink: 0
  width: 100%
  max-width: none
  padding: 0
  transition: opacity 0.2s ease-out

  &._transparent
    will-change: opacity

  @media screen and (min-width: $sidebar-width + $content-width + 40px)
    max-width: none

.content
  position: relative
  width: 100%
  padding: 0
  border-radius: 8px
  background-color: var(--content-item-background-color)
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.02)

.loader
  position: absolute
  top: 8px
  right: 8px
  width: 16px
  height: 16px

.menu
  top: 0
  right: 0
  width: 32px
  height: 32px
  border-radius: 0 8px 0 0
